# Agent mode: "fake" (demo script) eller "real" (Pump.fun on-chain)
NEXT_PUBLIC_AGENT_MODE=fake

# Kræves ved real mode – creator wallet der modtager fees
NEXT_PUBLIC_CREATOR_ADDRESS=

# Valgfrit – token mint for fee sharing / OnlinePumpSdk
NEXT_PUBLIC_MINT_ADDRESS=

# Solana RPC (default: mainnet)
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# Valgfrit – URL til agent backend der rapporterer stats (totalClaimed, totalBurned, osv.)
AGENT_STATS_API_URL=

# Agent kører separat (agent/ folder) – Pump SDK + PumpSwap SDK
