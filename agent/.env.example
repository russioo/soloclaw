# ========== AGENT – claim, buyback, burn, add LP ==========
# Kopier til .env:  cp .env.example .env

# Din wallet’s secret key (base58). HEMMELIG – del aldrig!
# Bruges til at signe transaktioner (claim, buyback, burn, LP).
AGENT_PRIVATE_KEY=

# Wallet der modtager 80% af fees. Ofte din egen adresse.
CREATOR_WALLET=

# Token mint-adresse (samme som på pump.fun).
MINT_ADDRESS=

# Valgfrit – RPC, min SOL før claim, interval
# RPC_URL=https://api.mainnet-beta.solana.com
# MIN_CLAIM_SOL=0.01
# CYCLE_INTERVAL_MS=180000
